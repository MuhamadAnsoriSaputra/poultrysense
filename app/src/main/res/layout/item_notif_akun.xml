<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_riwayat"
    android:orientation="vertical"
    android:padding="15dp"
    android:layout_marginBottom="15dp"
    android:elevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/img_notif_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_login"
            app:tint="@color/teal_primary" />

        <TextView
            android:id="@+id/txt_notif_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Peringatan Login Baru"
            android:textColor="@color/teal_primary"
            android:textStyle="bold"
            android:textSize="15sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/txt_notif_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="18 Mei 2026 - 06:10 AM"
        android:textColor="@color/text_gray"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/txt_notif_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Akun Anda baru saja login dari perangkat Samsung Galaxy S23 di Jakarta."
        android:textColor="@color/text_black"
        android:textSize="13sp"
        android:lineSpacingExtra="2dp"/>
</LinearLayout>
