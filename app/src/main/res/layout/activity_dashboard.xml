<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light_gray">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/nav_bottom_bar"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header Profile -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="25dp"
                android:layout_marginTop="30dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/txt_hi_user"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hi User,"
                        android:textSize="18sp"
                        android:textColor="@color/text_black"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome Back!"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_black"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_profile_switcher"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_pill"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_arrow_down_small"
                        app:tint="@color/text_black" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/img_profile"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/profil" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </RelativeLayout>

            <!-- Card Menu Utama -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="115dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/background_hijau" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="15dp"
                        android:weightSum="4">

                        <!-- Beri Pakan -->
                        <LinearLayout
                            android:id="@+id/menu_pakan"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:orientation="vertical">
                            <ImageView android:layout_width="45dp" android:layout_height="45dp" android:background="@drawable/bg_bulat_putih" android:padding="10dp" android:src="@drawable/ic_pakan_new" app:tint="@color/teal_primary"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Beri pakan" android:textColor="@color/white" android:textSize="10sp" android:layout_marginTop="5dp"/>
                        </LinearLayout>

                        <!-- Jadwal -->
                        <LinearLayout
                            android:id="@+id/menu_jadwal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:orientation="vertical">
                            <ImageView android:layout_width="45dp" android:layout_height="45dp" android:background="@drawable/bg_bulat_putih" android:padding="10dp" android:src="@drawable/ic_jadwal_new" app:tint="@color/teal_primary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jadwal" android:textColor="@color/white" android:textSize="10sp" android:layout_marginTop="5dp"/>
                        </LinearLayout>

                        <!-- Menu Riwayat -->
                        <LinearLayout
                            android:id="@+id/menu_riwayat"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:orientation="vertical">
                            <ImageView android:layout_width="45dp" android:layout_height="45dp" android:background="@drawable/bg_bulat_putih" android:padding="10dp" android:src="@drawable/ic_riwayat_new" app:tint="@color/teal_primary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Riwayat" android:textColor="@color/white" android:textSize="10sp" android:layout_marginTop="5dp"/>
                        </LinearLayout>

                        <!-- Menu Notifikasi -->
                        <LinearLayout
                            android:id="@+id/menu_notifikasi"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:orientation="vertical">
                            <ImageView android:layout_width="45dp" android:layout_height="45dp" android:background="@drawable/bg_bulat_putih" android:padding="10dp" android:src="@drawable/ic_notif_new" app:tint="@color/teal_primary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Notifikasi" android:textColor="@color/white" android:textSize="10sp" android:layout_marginTop="5dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Status Pakan -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                app:cardCornerRadius="25dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/teal_soft_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Status Pakan" android:textStyle="bold" android:textSize="18sp" android:textColor="@color/text_black"/>

                    <FrameLayout android:layout_width="180dp" android:layout_height="180dp" android:layout_gravity="center" android:layout_margin="15dp">
                        <ProgressBar android:id="@+id/progress_ring_pakan" android:layout_width="match_parent" android:layout_height="match_parent" android:indeterminate="false" android:progress="0" style="?android:attr/progressBarStyleHorizontal" android:progressDrawable="@drawable/custom_progress_ring" />
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:gravity="center" android:orientation="vertical">
                            <TextView android:id="@+id/txt_persentase_pakan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--%" android:textSize="32sp" android:textStyle="bold" android:textColor="@color/text_black"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sisa Pakan" android:textSize="14sp" android:textColor="@color/text_black"/>
                        </LinearLayout>
                    </FrameLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Frekuensi Beri Pakan (Minggu Ini)" android:textStyle="bold" android:textSize="14sp" android:textColor="@color/text_black" android:layout_marginBottom="15dp"/>
                    
                    <LinearLayout
                        android:id="@+id/chart_mingguan_container"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:orientation="horizontal"
                        android:weightSum="7"
                        android:gravity="bottom|center_horizontal"
                        android:baselineAligned="false">
                        <!-- Nanti diisi secara dinamis dari DashboardActivity.java -->
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Monitoring Konsumsi Harian -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="25dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/teal_soft_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Monitoring Konsumsi"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="@color/text_black"/>
                        
                        <TextView
                            android:id="@+id/txt_hari_ini"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Senin, 10 Mei"
                            android:textSize="12sp"
                            android:textColor="@color/text_gray"/>
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/pakan"
                            app:tint="@color/teal_primary"
                            android:background="@drawable/bg_bulat_putih"
                            android:padding="12dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="15dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Konsumsi Hari Ini"
                                android:textSize="14sp"
                                android:textColor="@color/text_gray"/>
                            <TextView
                                android:id="@+id/txt_konsumsi_gram"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1.250 g"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_black"/>
                        </LinearLayout>
                    </LinearLayout>
                    
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:background="@color/border_gray"
                        android:alpha="0.3"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="15dp"
                        android:orientation="horizontal"
                        android:weightSum="2">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Estimasi Sisa"
                                android:textSize="12sp"
                                android:textColor="@color/text_gray"/>
                            <TextView
                                android:id="@+id/txt_sisa_gram"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3.750 g"
                                android:textStyle="bold"
                                android:textColor="@color/text_black"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Status"
                                android:textSize="12sp"
                                android:textColor="@color/text_gray"/>
                            <TextView
                                android:id="@+id/txt_status_pakan_monitor"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cukup"
                                android:textStyle="bold"
                                android:textColor="@color/teal_primary"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Jadwal -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="15dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/teal_soft_card"
                    android:orientation="vertical"
                    android:padding="15dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jadwal Pakan Aktif" android:textStyle="bold" />
                    <TextView
                        android:id="@+id/txt_jadwal_aktif"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Belum ada jadwal aktif"
                        android:textColor="@color/text_gray"
                        android:layout_marginTop="5dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/nav_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="85dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@color/white"
            android:elevation="8dp"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/nav_home"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_nav_home"
                app:tint="@color/teal_primary"/>

            <ImageView
                android:id="@+id/nav_notif"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_nav_notification"
                app:tint="@color/text_gray"/>

            <!-- Spacer for Center Button -->
            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/nav_history"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_nav_history"
                app:tint="@color/text_gray"/>

            <ImageView
                android:id="@+id/nav_profile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_nav_profile"
                app:tint="@color/text_gray"/>
        </LinearLayout>

        <!-- Center Floating Pakan Button -->
        <androidx.cardview.widget.CardView
            android:id="@+id/nav_pakan"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginBottom="25dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/text_gray"
            app:cardCornerRadius="30dp"
            app:cardElevation="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="15dp"
                android:src="@drawable/ic_pakan_action"
                app:tint="@color/white" />
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>