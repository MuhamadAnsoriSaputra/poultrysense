<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="12dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp">

        <ImageView
            android:id="@+id/img_icon_history"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/pakan" />

        <LinearLayout
            android:id="@+id/layout_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_toEndOf="@id/img_icon_history"
            android:layout_toStartOf="@+id/btn_delete_history"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txt_title_history"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pemberian pakan"
                android:textColor="@color/teal_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_tipe_history"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manual - 200g"
                android:textColor="@color/text_black"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_time_history"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25 Maret 2026 - 09:00 PM"
                android:textColor="@color/text_gray"
                android:textSize="11sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_delete_history"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="8dp"
            android:padding="4dp"
            android:src="@drawable/sampah"
            app:tint="@color/text_gray" />

    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="52dp"
        android:background="@color/border_gray" />
</LinearLayout>