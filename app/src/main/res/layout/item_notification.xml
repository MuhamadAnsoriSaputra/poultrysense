<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="15dp"
    android:layout_marginVertical="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/img_notif_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_bulat_putih"
            android:padding="10dp"
            android:src="@drawable/logo_app" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/txt_notif_judul"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Judul Notifikasi"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_black"/>

                <TextView
                    android:id="@+id/txt_notif_kategori"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/bg_pill"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="Sistem"
                    android:textSize="10sp"
                    android:textColor="@color/teal_primary"
                    android:textStyle="bold"/>
            </RelativeLayout>

            <TextView
                android:id="@+id/txt_notif_pesan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Pesan detail notifikasi muncul di sini..."
                android:textSize="13sp"
                android:textColor="@color/text_gray"/>

            <TextView
                android:id="@+id/txt_notif_waktu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="18 Mei 2026 - 10:00 AM"
                android:textSize="11sp"
                android:textColor="#B0B0B0"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/img_select_notif"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/ic_circle_unchecked"
            android:visibility="gone" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
